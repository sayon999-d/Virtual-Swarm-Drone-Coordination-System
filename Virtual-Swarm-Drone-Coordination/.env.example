# GROQ_API_KEY: Server-side key for the leader brain.
# Keep this in .env only. Do not expose it as a VITE_* variable.
GROQ_API_KEY="MY_GROQ_API_KEY"

# GROQ_MODEL: Model used by the leader planner.
# Use a smaller model if you hit TPM limits often.
GROQ_MODEL="llama-3.1-8b-instant"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
